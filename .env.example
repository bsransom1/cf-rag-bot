# OpenAI
# Required for embeddings (ingest + retrieval) and chat completions.
OPENAI_API_KEY=

# Supabase
# Project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=
# Anon key — used by the Next.js runtime to call the `match_documents` RPC.
# Safe to expose in client code if ever needed.
SUPABASE_ANON_KEY=
# Service role key — ingestion script AND /api/chat transcript logging (server only).
# NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Browser / middleware (Supabase Auth for /login and /dashboard).
# Use the SAME values as SUPABASE_URL and SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: additional Supabase projects (multi-database / per-site isolation).
# Set `databaseProfileId` on a project in lib/config/project.ts (e.g. "eu"),
# then define credentials with the profile id uppercased as the env suffix:
# SUPABASE_URL_EU=
# SUPABASE_ANON_KEY_EU=
# SUPABASE_SERVICE_ROLE_KEY_EU=
