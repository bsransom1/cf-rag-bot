# OpenAI
# Required for embeddings (ingest + retrieval) and chat completions.
OPENAI_API_KEY=

# Supabase
# Project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=
# Anon key — used by the Next.js runtime to call the `match_documents` RPC.
# Safe to expose in client code if ever needed.
SUPABASE_ANON_KEY=
# Service role key — ONLY used by the ingestion script to insert rows.
# NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Speech-to-text (browser dictation)
# No env vars — uses the Web Speech API in the client (Chrome / Edge / Safari).
# Production must be served over HTTPS (or localhost) for microphone access.
